<mujoco model="arm2dof">
  <compiler angle="degree"/>
  <option timestep="0.02" gravity="0 0 -9.81"/>

  <visual>
    <headlight ambient="0.6 0.6 0.6" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.95 0.95 0.95" rgb2="0.7 0.8 0.9" width="256" height="256"/>
    <material name="ground" rgba="0.9 0.9 0.9 1"/>
    <material name="link1_mat" rgba="0.2 0.4 0.9 1"/>
    <material name="link2_mat" rgba="0.9 0.4 0.2 1"/>
    <material name="ee_mat" rgba="0.2 0.8 0.3 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="3 3 0.1" material="ground"/>

    <camera name="front" pos="1.6 0 0.9" xyaxes="0 1 0 -0.35 0 1"/>
    <camera name="top" pos="0 0 2.2" xyaxes="1 0 0 0 1 0"/>

    <body name="base" pos="0 0 0.1">
      <geom type="cylinder" size="0.08 0.08" rgba="0.3 0.3 0.3 1"/>

      <body name="link1_body" pos="0 0 0.08">
        <joint name="joint1" type="hinge" axis="0 0 1" range="-180 180" damping="1"/>
        <geom name="link1" type="capsule" fromto="0 0 0 0.45 0 0" size="0.04" material="link1_mat"/>

        <body name="link2_body" pos="0.45 0 0">
          <joint name="joint2" type="hinge" axis="0 0 1" range="-180 180" damping="1"/>
          <geom name="link2" type="capsule" fromto="0 0 0 0.35 0 0" size="0.035" material="link2_mat"/>

          <body name="ee" pos="0.35 0 0">
            <geom name="ee_geom" type="sphere" size="0.05" material="ee_mat"/>
            <site name="ee_site" pos="0 0 0" size="0.02" rgba="1 1 0 1"/>

            <!-- Caméra embarquée sur l’organe terminal -->
            <camera name="wrist_cam" pos="0.08 0 0.02" xyaxes="1 0 0 0 0 -1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="motor1" joint="joint1" gear="25" ctrlrange="-1 1" ctrllimited="true"/>
    <motor name="motor2" joint="joint2" gear="25" ctrlrange="-1 1" ctrllimited="true"/>
  </actuator>
</mujoco>
