          pos="-0.05 0.56 -0.12"
          euler="0 0 0"
          size="0.01"
          rgba="0 1 0 1"/>

      -->
      
    </body>
    

    <body name="microwave_rectangle" pos="0.9 -0.33 0.58" euler="0 0 1.57">
      <freejoint/>
      <geom type="box" size="0.015 0.05 0.02" rgba="0.71 0.72 0.695 1"
            mass="0.1"
            friction="2.0 0.1 0.002"
            solimp="0.995 0.9999 0.0005"
            solref="0.001 1"
            condim="4"/>
    </body>

    <body name="microwave_transformer" pos="0.9 -0.20 0.60" euler="0 0 1.57">
      <freejoint/>
      <geom type="box" size="0.035 0.055 0.0475" rgba="0.2 0.2 0.2 1"
          mass="5.0"
          friction="2.0 0.1 0.002"
          solimp="0.995 0.9999 0.0005"
          solref="0.001 1"
          condim="4"/>

      <geom type="box" size="0.07 0.03 0.02" rgba="0.74 0.53 0.44 1"
          mass="5.0"
          friction="2.0 0.1 0.002"
          solimp="0.995 0.9999 0.0005"
          solref="0.001 1"
          condim="4"/>
    </body> 
