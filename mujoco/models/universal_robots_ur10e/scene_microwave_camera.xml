<mujoco model="ur10e custom scene">
  <include file="ur10e_with_gripper.xml"/>

  <statistic center="0.5 0 0.55" extent="1.6"/>

  <visual>

    <headlight diffuse="0.6 0.6 0.6" ambient="0.15 0.15 0.15" specular="0 0 0"/>
    <!-- <headlight diffuse="0.3 0.3 0.3" ambient="0.05 0.05 0.05" specular="0.3 0.3 0.3"/> -->

    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20" offwidth="1280" offheight="720"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient"
             rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>

    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>

    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.2"/>

    <material name="stand_mat" rgba="0.35 0.35 0.38 1"/>
    <material name="table_mat" rgba="0.55 0.42 0.30 1"/>
    <material name="workspace_mat" rgba="0.2 0.7 0.2 0.25"/>
    <material name="cube_mat" rgba="0.85 0.2 0.2 1"/>
    <material name="leg_mat" rgba="0.2 0.2 0.2 1"/>

    <mesh name="microwave" file="microwave_narrow.obj" scale="0.01 0.01 0.01"/>
  </asset>

  <worldbody>
    <light pos="0 0 2.5" dir="0 0 -1" directional="true"/>
    <!-- <light pos="0 0 2.5" dir="0 0 -1" directional="true" diffuse="0.5 0.5 0.5"/> -->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <camera name="front" pos="2.2 0 1.2" xyaxes="0 1 0 -0.45 0 1"/>
    
    <!-- ANCIENNE CAMERA (Axe de base) -->
    <!-- <camera name="top_table" pos="0.75 0.03 1.80" xyaxes="1 0 0 0 1 0"/> -->
    
    <!-- NOUVELLE CAMERA POUR LE FUTUR (Orientation corrigée dans le XML pour éviter cv2.rotate) -->
    <camera name="top_table" pos="0.75 0.03 1.80" xyaxes="0 -1 0 1 0 0"/>

    <body name="robot_stand" pos="0 0 0.2">
      <geom name="stand" type="box" size="0.18 0.18 0.2" material="stand_mat"/>
    </body>

    <body name="table" pos="1.1 0 0.51">
      <geom name="table_top" type="box" size="0.4 0.90 0.02" material="table_mat"
        friction="2.0 0.1 0.002" solimp="0.995 0.9999 0.0005" solref="0.001 1" condim="4"/>


      <geom name="leg1" type="box" pos=" 0.37  0.87 -0.265" size="0.03 0.03 0.245" material="leg_mat"/>
      <geom name="leg2" type="box" pos=" 0.37 -0.87 -0.265" size="0.03 0.03 0.245" material="leg_mat"/>
      <geom name="leg3" type="box" pos="-0.37  0.87 -0.265" size="0.03 0.03 0.245" material="leg_mat"/>
      <geom name="leg4" type="box" pos="-0.37 -0.87 -0.265" size="0.03 0.03 0.245" material="leg_mat"/>
    </body>

 
    <body name="target_box_transformer" pos="0.9 0.40 0.53">
      <geom name="box_base" type="box" size="0.08 0.08 0.005" pos="0 0 0.005" rgba="0.2 0.5 0.8 1"
        friction="2.0 0.1 0.002" solimp="0.995 0.9999 0.0005" solref="0.001 1" condim="4" />
      <geom name="box_wall1" type="box" size="0.08 0.005 0.04" pos="0  0.075 0.045" rgba="0.2 0.5 0.8 0.6"
        friction="2.0 0.1 0.002" solimp="0.995 0.9999 0.0005" solref="0.001 1" condim="4" />
      <geom name="box_wall2" type="box" size="0.08 0.005 0.04" pos="0 -0.075 0.045" rgba="0.2 0.5 0.8 0.6"
        friction="2.0 0.1 0.002" solimp="0.995 0.9999 0.0005" solref="0.001 1" condim="4" />
      <geom name="box_wall3" type="box" size="0.005 0.08 0.04" pos=" 0.075 0 0.045" rgba="0.2 0.5 0.8 0.6"
        friction="2.0 0.1 0.002" solimp="0.995 0.9999 0.0005" solref="0.001 1" condim="4" />
      <geom name="box_wall4" type="box" size="0.005 0.08 0.04" pos="-0.075 0 0.045" rgba="0.2 0.5 0.8 0.6"
        friction="2.0 0.1 0.002" solimp="0.995 0.9999 0.0005" solref="0.001 1" condim="4" />
    </body>

    <body name="target_box_metal" pos="0.9 0.20 0.53">
      <geom name="box_base_metal" type="box" size="0.08 0.08 0.005" pos="0 0 0.005" rgba="0.8 0.8 0.8 1"
        friction="2.0 0.1 0.002" solimp="0.995 0.9999 0.0005" solref="0.001 1" condim="4" />

      <geom name="box_wall1_metal" type="box" size="0.08 0.005 0.04" pos="0  0.075 0.045" rgba="0.8 0.8 0.8 0.6"
        friction="2.0 0.1 0.002" solimp="0.995 0.9999 0.0005" solref="0.001 1" condim="4" />

      <geom name="box_wall2_metal" type="box" size="0.08 0.005 0.04" pos="0 -0.075 0.045" rgba="0.8 0.8 0.8 0.6"
        friction="2.0 0.1 0.002" solimp="0.995 0.9999 0.0005" solref="0.001 1" condim="4"/>

      <geom name="box_wall3_metal" type="box" size="0.005 0.08 0.04" pos=" 0.075 0 0.045" rgba="0.8 0.8 0.8 0.6"
        friction="2.0 0.1 0.002" solimp="0.995 0.9999 0.0005" solref="0.001 1" condim="4" />

      <geom name="box_wall4_metal" type="box" size="0.005 0.08 0.04" pos="-0.075 0 0.045" rgba="0.8 0.8 0.8 0.6"
        friction="2.0 0.1 0.002" solimp="0.995 0.9999 0.0005" solref="0.001 1" condim="4" />
    </body>

    <body name="microwave" pos="1.4 -0.4 0.8" euler="0 0 1.57">
      <geom type="mesh" mesh="microwave"
            contype="0" conaffinity="0"
            group="0"/>

        <!-- fond -->
      <geom type="box" pos="0.16 0.40 -0.15" size="0.15 0.02 0.16"
            friction="2.0 0.1 0.002" rgba="1 0 0 0"/>

        <!-- bas -->
      <geom type="box" pos=" 0.16 0.49 -0.27" size="0.15 0.08 0.01"
            friction="2.0 0.1 0.002" rgba="1 0 0 0"/>
      <!-- haut -->
      <geom type="box" pos=" 0.156 0.49 -0.071" size="0.151 0.08 0.07"
            friction="2.0 0.1 0.002" rgba="1 0 0 0"/>

        <!-- droite -->
      <geom type="box" pos="0.00 0.49 -0.15" size="0.01 0.08 0.15"
            friction="2.0 0.1 0.002" rgba="1 0 0 0"/>
        <!-- droite block -->
      <geom type="box" pos="0.03 0.49 -0.091" size="0.035 0.08 0.087"
            friction="2.0 0.1 0.002" rgba="1 0 0 0"/>
        <!-- gauche -->
      <geom type="box" pos="0.305 0.49 -0.15" size="0.007 0.08 0.15"
            friction="2.0 0.1 0.002" rgba="1 0 0 0"/>
      <!--
