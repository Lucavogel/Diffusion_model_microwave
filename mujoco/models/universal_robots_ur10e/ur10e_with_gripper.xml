<mujoco model="ur10e">
  <compiler angle="radian" meshdir="assets" autolimits="true" />

  <option integrator="implicitfast" />

  <default>
    <default class="ur10e">
      <material specular="0.5" shininess="0.25" />
      <joint axis="0 1 0" range="-6.28319 6.28319" armature="0.1" />
      <position ctrlrange="-6.2831 6.2831" />
      <general biastype="affine" ctrlrange="-6.2831 6.2831" gainprm="5000" biasprm="0 -5000 -500" />
      <default class="size4">
        <joint damping="10" />
        <general forcerange="-330 330" />
      </default>
      <default class="size3">
        <joint damping="5" />
        <general forcerange="-150 150" />
        <default class="size3_limited">
          <joint range="-3.1415 3.1415" />
          <general ctrlrange="-3.1415 3.1415" />
        </default>
      </default>
      <default class="size2">
        <joint damping="2" />
        <general forcerange="-56 56" />
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2" />
      </default>
      <default class="collision">
        <geom type="capsule" group="3" />
        <default class="eef_collision">
          <geom type="cylinder" />
        </default>
      </default>
      <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4" />
    </default>
  </default>

  <asset>
    <material class="ur10e" name="black" rgba="0.033 0.033 0.033 1" />
    <material class="ur10e" name="jointgray" rgba="0.278 0.278 0.278 1" />
    <material class="ur10e" name="linkgray" rgba="0.82 0.82 0.82 1" />
    <material class="ur10e" name="urblue" rgba="0.49 0.678 0.8 1" />

    <mesh file="base_0.obj" />
    <mesh file="base_1.obj" />
    <mesh file="shoulder_0.obj" />
    <mesh file="shoulder_1.obj" />
    <mesh file="shoulder_2.obj" />
    <mesh file="upperarm_0.obj" />
    <mesh file="upperarm_1.obj" />
    <mesh file="upperarm_2.obj" />
    <mesh file="upperarm_3.obj" />
    <mesh file="forearm_0.obj" />
    <mesh file="forearm_1.obj" />
    <mesh file="forearm_2.obj" />
    <mesh file="forearm_3.obj" />
    <mesh file="wrist1_0.obj" />
    <mesh file="wrist1_1.obj" />
    <mesh file="wrist1_2.obj" />
    <mesh file="wrist2_0.obj" />
    <mesh file="wrist2_1.obj" />
    <mesh file="wrist2_2.obj" />
    <mesh file="wrist3.obj" />

    <mesh name="quick_changer" content_type="model/stl" file="../pince/OnRobot-RG2FT-ROS/onrobot_rg2ft_description/urdf/quick_changer.stl" scale="0.001 0.001 0.001" />
    <mesh name="gripper_body" content_type="model/stl" file="../pince/OnRobot-RG2FT-ROS/onrobot_rg2ft_description/urdf/gripper_body.stl" scale="0.001 0.001 0.001" />
    <mesh name="angle_bracket" content_type="model/stl" file="../pince/OnRobot-RG2FT-ROS/onrobot_rg2ft_description/urdf/angle_bracket.stl" scale="0.001 0.001 0.001" />
    <mesh name="left_inner_knuckle" content_type="model/stl" file="../pince/OnRobot-RG2FT-ROS/onrobot_rg2ft_description/urdf/left_inner_knuckle.stl" scale="0.001 0.001 0.001" />
    <mesh name="right_outer_knuckle" content_type="model/stl" file="../pince/OnRobot-RG2FT-ROS/onrobot_rg2ft_description/urdf/right_outer_knuckle.stl" scale="0.001 0.001 0.001" />
    <mesh name="left_outer_knuckle" content_type="model/stl" file="../pince/OnRobot-RG2FT-ROS/onrobot_rg2ft_description/urdf/left_outer_knuckle.stl" scale="0.001 0.001 0.001" />
    <mesh name="left_inner_finger" content_type="model/stl" file="../pince/OnRobot-RG2FT-ROS/onrobot_rg2ft_description/urdf/left_inner_finger.stl" scale="0.001 0.001 0.001" />
    <mesh name="right_inner_finger" content_type="model/stl" file="../pince/OnRobot-RG2FT-ROS/onrobot_rg2ft_description/urdf/right_inner_finger.stl" scale="0.001 0.001 0.001" />
    <mesh name="right_inner_knuckle" content_type="model/stl" file="../pince/OnRobot-RG2FT-ROS/onrobot_rg2ft_description/urdf/right_inner_knuckle.stl" scale="0.001 0.001 0.001" />
  </asset>

  <worldbody>
    <light name="spotlight" mode="targetbodycom" target="wrist_2_link" pos="0 -1 2" />

    <body name="base" pos="0 0 0.4" quat="1 0 0 0" childclass="ur10e">
      <inertial mass="4.0" pos="0 0 0" diaginertia="0.0061063308908 0.0061063308908 0.01125" />
      <geom mesh="base_0" material="black" class="visual" />
      <geom mesh="base_1" material="jointgray" class="visual" />

      <body name="shoulder_link" pos="0 0 0.181">
        <inertial pos="0 0 0" mass="7.778" diaginertia="0.0314743 0.0314743 0.0218756" />
        <joint name="shoulder_pan_joint" class="size4" axis="0 0 1" />
        <geom mesh="shoulder_0" material="urblue" class="visual" />
        <geom mesh="shoulder_1" material="black" class="visual" />
        <geom mesh="shoulder_2" material="jointgray" class="visual" />
        <geom class="collision" size="0.078 0.08" pos="0 0 -0.05" />

        <body name="upper_arm_link" pos="0 0.176 0" quat="1 0 1 0">
          <inertial pos="0 0 0.3065" mass="12.93" diaginertia="0.423074 0.423074 0.0363656" />
          <joint name="shoulder_lift_joint" class="size4" />
          <geom mesh="upperarm_0" material="black" class="visual" />
          <geom mesh="upperarm_1" material="jointgray" class="visual" />
          <geom mesh="upperarm_2" material="urblue" class="visual" />
          <geom mesh="upperarm_3" material="linkgray" class="visual" />
          <geom class="collision" pos="0 -0.05 0" quat="1 1 0 0" size="0.078 0.08" />
          <geom class="collision" size="0.06 0.3" pos="0 0 0.3" />

          <body name="forearm_link" pos="0 -0.137 0.613">
            <inertial pos="0 0 0.2855" mass="3.87" diaginertia="0.11059 0.11059 0.0108844" />
            <joint name="elbow_joint" class="size3_limited" />
            <geom mesh="forearm_0" material="urblue" class="visual" />
            <geom mesh="forearm_1" material="black" class="visual" />
            <geom mesh="forearm_2" material="jointgray" class="visual" />
            <geom mesh="forearm_3" material="linkgray" class="visual" />
            <geom class="collision" pos="0 0.08 0" quat="1 1 0 0" size="0.058 0.065" />
            <geom class="collision" size="0.043 0.28" pos="0 0 0.29" />

            <body name="wrist_1_link" pos="0 0 0.571" quat="1 0 1 0">
              <inertial pos="0 0.135 0" quat="0.5 0.5 -0.5 0.5" mass="1.96" diaginertia="0.0055125 0.00510825 0.00510825" />
              <joint name="wrist_1_joint" class="size2" />
              <geom mesh="wrist1_0" material="black" class="visual" />
              <geom mesh="wrist1_1" material="urblue" class="visual" />
              <geom mesh="wrist1_2" material="jointgray" class="visual" />
              <geom class="collision" pos="0 0.06 0" quat="1 1 0 0" size="0.05 0.07" />

              <body name="wrist_2_link" pos="0 0.135 0">
                <inertial pos="0 0 0.12" quat="0.5 0.5 -0.5 0.5" mass="1.96" diaginertia="0.0055125 0.00510825 0.00510825" />
                <joint name="wrist_2_joint" axis="0 0 1" class="size2" />
                <geom mesh="wrist2_0" material="black" class="visual" />
                <geom mesh="wrist2_1" material="urblue" class="visual" />
                <geom mesh="wrist2_2" material="jointgray" class="visual" />
                <geom class="collision" size="0.046 0.065" pos="0 0 0.05" />
                <geom class="collision" pos="0 0.028 0.12" quat="1 1 0 0" size="0.046 0.043" />

                <body name="wrist_3_link" pos="0 0 0.12">
                  <inertial pos="0 0.092 0" quat="0 1 -1 0" mass="0.202" diaginertia="0.000204525 0.000144346 0.000144346" />
                  <joint name="wrist_3_joint" class="size2" />
                  <geom material="linkgray" mesh="wrist3" class="visual" />
                  <geom class="eef_collision" pos="0 0.097 0" quat="1 1 0 0" size="0.046 0.02" />
                  <site name="attachment_site" pos="0 0.1 0" quat="-1 1 0 0" />
                  <!-- ANCIENNE CAMERA (Axe de base) -->
                  <!-- <camera name="wrist_cam" pos="0.00 0.00 -0.1" xyaxes="1 0 0 0 0 1" /> -->
                  
                  <!-- NOUVELLE CAMERA POUR LE FUTUR (Orientation corrigée dans le XML pour éviter cv2.rotate) -->
                  <camera name="wrist_cam" pos="0.00 0.00 -0.1" xyaxes="-1 0 0 0 0 -1" />

                  <body name="rg2ft_gripper" pos="0 0 0" quat="-1 1 0 0">
                    <geom pos="0 0 0.1" quat="1 0 0 0"
                          type="mesh" rgba="0.215686 0.592157 0.811765 1"
                          mesh="quick_changer" contype="0" conaffinity="0" />

                    <geom pos="0 0 0.1" quat="1 0 0 0"
                          type="mesh" rgba="0.7 0.7 0.7 1"
                          mesh="angle_bracket" contype="0" conaffinity="0" />

                    <geom pos="0 0.000475769 0.100002" quat="0.999987 0.00506143 0 0"
                          type="mesh" rgba="0.7 0.7 0.7 1"
                          mesh="gripper_body" contype="0" conaffinity="0" />

                    <!-- côté droit motorisé -->
                    <body name="right_outer_knuckle" pos="-0.017 -0.0103018 0.222798"
                          quat="0.978496 0.00495266 -0.206202 -0.00104369">
                      <inertial pos="-0.0123122 0.0103697 0.0102038"
                                quat="0 0.92388 0 0.382683"
                                mass="0.0415837"
                                diaginertia="1.7e-05 1.6e-05 3e-06" />

                      <joint name="finger_joint"
                             pos="0 0 0"
                             axis="0 0.999949 -0.010122"
                             range="-0.2 1.2"
                             actuatorfrcrange="-50 50"
                             damping="5.0"
                             armature="0.05" />

                      <geom pos="0.017 0.009534 -0.122898"
                            type="mesh" rgba="0.7 0.7 0.7 1"
                            mesh="right_outer_knuckle"
                            contype="0" conaffinity="1" />

                      <!-- doigt droit libéré avec son articulation de compensation -->
                      <body name="right_inner_finger" pos="-0.039748 0.004784 0.037968"
                            quat="0.978509 0 0.206204 0">
                        
                        <!-- NOUVEAU JOINT ICI -->
                        <joint name="right_inner_finger_joint"
                               pos="0 0 0"
                               axis="0 0.999949 -0.010122"
                               range="-1.68 0.2"
                               damping="5.0"
                               armature="0.05" />

                        <geom pos="0.056748 0.00475 -0.160866"
                              type="mesh" rgba="0.7 0.7 0.7 1"
                              mesh="right_inner_finger"
                              contype="0" conaffinity="1" friction="3.0 0.1 0.002" solimp="0.99 0.999 0.001" solref="0.004 1" margin="0.001" condim="4" />
                        <!-- 
                        <geom type="cylinder" size="0.014 0.004 0.005" pos="0.0149 0.0064 0.040" axisangle="0 1 0 1.5708"
                          contype="0" conaffinity="0"
                          group="0" rgba="1 0 0 1" />
                          -->
                      </body>
                    </body>

                    <!--côté gauche en mimic -->
                    <body name="left_outer_knuckle" pos="0.017 -0.0103018 0.222798"
                          quat="0.978496 0.00495266 0.206202 0.00104369">
                      <inertial pos="0.012312 0.0103697 0.0102038"
                                quat="0.92388 0 0.382683 0"
                                mass="0.0415837"
                                diaginertia="1.7e-05 1.6e-05 3e-06" />

                      <joint name="left_outer_knuckle_joint"
                             pos="0 0 0"
                             axis="0 0.999949 -0.010122"
                             range="-1.69 0.21"
                             actuatorfrcrange="-50 50"
                             damping="5.0"
                             armature="0.05" />

                      <geom pos="-0.017 0.009534 -0.122898"
                            type="mesh" rgba="0.7 0.7 0.7 1"
                            mesh="left_outer_knuckle"
                            contype="0" conaffinity="1" />

                      <!-- doigt gauche rigidement attaché -->
                                            <!-- doigt gauche libéré avec son articulation de compensation -->
                      <body name="left_inner_finger" pos="0.039748 0.004784 0.037968"
                            quat="0.978509 0 -0.206204 0">
                        
                        <!-- NOUVEAU JOINT ICI -->
                        <joint name="left_inner_finger_joint"
                               pos="0 0 0"
                               axis="0 0.999949 -0.010122"
                               range="-0.2 1.68"
                               damping="5.0"
                               armature="0.05" />

                        <geom pos="-0.056748 0.00475 -0.160866"
                              type="mesh" rgba="0.7 0.7 0.7 1"
                              mesh="left_inner_finger"
                              contype="0" conaffinity="1" friction="3.0 0.1 0.002" solimp="0.99 0.999 0.001" solref="0.004 1" margin="0.001" condim="4" />
                        <!--
                        <geom type="cylinder" size="0.014 0.004 0.005" pos="-0.0149 0.0064 0.040" axisangle="0 1 0 1.5708"
                          contype="0" conaffinity="0"
                          group="0" rgba="1 0 0 1" />
                  -->
                      </body>
                    </body>

                    <!-- barres internes visuelles -->
                    <body name="left_inner_knuckle" pos="0.0075 -0.0103018 0.239297"
                          quat="0.978496 0.00495266 0.206202 0.00104369">
                      
                      <!-- 1. Inertie -->
                      <inertial pos="0.0176 0.0104 0.017" mass="0.024" diaginertia="5e-6 7e-6 5e-6" />
                      
                      <!-- 2. Articulation -->
                      <joint name="left_inner_knuckle_joint"
                             pos="0 0 0"
                             axis="0 0.999949 -0.010122"
                             range="-1.69 0.21"
                             damping="5.0"
                             armature="0.05" />

                      <geom pos="-0.0075 0.009367 -0.139397"
                            quat="1 0 0 0"
                            type="mesh" rgba="0.7 0.7 0.7 1"
                            mesh="left_inner_knuckle"
                            contype="0" conaffinity="1" />
                    </body>

                    <body name="right_inner_knuckle" pos="-0.0075 -0.0103018 0.239297"
                          quat="0.978496 0.00495266 -0.206202 -0.00104369">
                      
                      <!-- 1. Inertie -->
                      <inertial pos="-0.0176 0.0104 0.017" mass="0.024" diaginertia="5e-6 7e-6 5e-6" />
                      
                      <!-- 2. Articulation -->
                      <joint name="right_inner_knuckle_joint"
                             pos="0 0 0"
                             axis="0 0.999949 -0.010122"
                             range="-0.2 1.68"
                             damping="5.0"
                             armature="0.05" />

                      <geom pos="0.0075 0.009367 -0.139397"
                            quat="1 0 0 0"
                            type="mesh" rgba="0.7 0.7 0.7 1"
                            mesh="right_inner_knuckle"
                            contype="0" conaffinity="1" />
                    </body>

                    <!-- Point de pincer (Grasp Site / TCP pour IK) placé au centre de la pince -->
                    <site name="grasp_site" pos="0 0 0.31" size="0.01" rgba="0 1 0 1" group="1" />

                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <general class="size4" name="shoulder_pan" joint="shoulder_pan_joint" />
    <general class="size4" name="shoulder_lift" joint="shoulder_lift_joint" />
    <general class="size3_limited" name="elbow" joint="elbow_joint" />
    <general class="size2" name="wrist_1" joint="wrist_1_joint" />
    <general class="size2" name="wrist_2" joint="wrist_2_joint" />
    <general class="size2" name="wrist_3" joint="wrist_3_joint" />

    <position name="gripper_motor"
              joint="finger_joint"
              ctrlrange="-0.2 1.2"
              kp="800"
              forcerange="-50 50" />
  </actuator>

  <keyframe>
    <key name="home"
         qpos="-1.5708 -1.5708 1.5708 -1.5708 -1.5708 0"
         ctrl="-1.5708 -1.5708 1.5708 -1.5708 -1.5708 0" />
  </keyframe>

  <equality>
    <!-- Contrainte existante pour le doigt gauche -->
    <joint name="mimic_left_outer"
           joint1="finger_joint"
           joint2="left_outer_knuckle_joint"
           polycoef="0 -1 0 0 0"
           solimp="0.99 0.99 0.001"
           solref="0.005 1" />

    <!-- Contrainte pour la barre intérieure droite (Tourne dans le même sens : 1) -->
    <joint name="mimic_right_inner"
           joint1="finger_joint"
           joint2="right_inner_knuckle_joint"
           polycoef="0 1 0 0 0"
           solimp="0.99 0.99 0.001"
           solref="0.005 1"/>

    <!-- NOUVELLE: Contrainte pour le bout du doigt (Compense dans le sens inverse : -1) -->
    <joint name="mimic_right_finger"
           joint1="finger_joint"
           joint2="right_inner_finger_joint"
           polycoef="0 -1 0 0 0"
           solimp="0.99 0.99 0.001"
           solref="0.005 1" />

        <!-- NOUVELLE : La barre intérieure gauche ferme (sens -1 comme le bras principal gauche) -->
    <joint name="mimic_left_inner"
           joint1="finger_joint"
           joint2="left_inner_knuckle_joint"
           polycoef="0 -1 0 0 0"
           solimp="0.99 0.99 0.001"
           solref="0.005 1" />

    <!-- NOUVELLE : Le bout du doigt gauche compense (sens 1 pour contrer le -1) -->
    <joint name="mimic_left_finger"
           joint1="finger_joint"
           joint2="left_inner_finger_joint"
           polycoef="0 1 0 0 0"
           solimp="0.99 0.99 0.001"
           solref="0.005 1" />


  </equality>
</mujoco>